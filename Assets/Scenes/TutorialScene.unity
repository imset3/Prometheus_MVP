  m_EditorClassIdentifier: Narthex.Presentation::Narthex.Presentation.TutorialDialoguePresenter
  serviceRoot: {fileID: 465223170}
  playerInputHost: {fileID: 397905168}
  dialogueView: {fileID: 714094749}
  introductionCard: {fileID: 1429360762}
  continuePrompt: "SPACE: \uB2E4\uC74C"
  closePrompt: "SPACE: \uB2EB\uAE30"
  introductionDefinitions:
  - questId: QST-TUTO-001
    displayName: "\uD14C\uC6B0\uC2A4"
    englishName: Theus
    description: "\uC544\uB2E4\uB9C8\uC2A4\uC758 \uBA64\uBC84\uC774\uC790 \uD504\uB85C\uBA54\uC758
      \uC5EC\uD589\uC744 \uB3D5\uB294 AI.\n\uBAA8\uD5D8 \uC911 \uB9CC\uB098\uB294
      \uBB3C\uAC74\uACFC \uC7A5\uC18C\uB97C \uBD84\uC11D\uD574 \uC548\uB0B4\uD55C\uB2E4."
  - questId: QST-TUTO-007
    displayName: "\uD06C\uB9AC\uC628"
    englishName: Cryon
    description: "\uC544\uB2E4\uB9C8\uC2A4\uC758 \uC815\uCC30 \uB300\uC6D0.\n\uD0D0\uC0AC
      \uC7A5\uBE44\uB97C \uAD00\uB9AC\uD558\uBA70 \uD504\uB85C\uBA54\uC758 \uC774\uB3D9\uC744
      \uC9C0\uC6D0\uD55C\uB2E4."
  - questId: QST-TUTO-005
    displayName: "\uB098\uB974\uD14D\uC2A4 \uD384\uC2A4 \uBAA8\uB4C8"
    englishName: Narthex Pulse
    description: "\uC804\uBC29\uC5D0 \uC5D0\uB108\uC9C0 \uD30C\uB3D9\uC744 \uBC1C\uC0AC\uD558\uB294
      \uAE30\uBCF8 \uBAA8\uB4C8.\n2\uB97C \uB20C\uB7EC \uC801\uACFC \uC7A5\uCE58\uC5D0
      \uD384\uC2A4\uB97C \uC0AC\uC6A9\uD55C\uB2E4."
  - questId: QST-TUTO-008
    displayName: "\uD5EC\uD14C"
    englishName: Helte
    description: "\uAD11\uBB3C \uBCF4\uAD00\uC18C\uB97C \uC9C0\uD0A4\uB294 \uC801\uB300
      \uAC1C\uCCB4.\n\uD328\uD134\uC744 \uD53C\uD558\uACE0 \uACF5\uACA9\uACFC \uD384\uC2A4\uB97C
      \uC870\uD569\uD574 \uCC98\uCE58\uD55C\uB2E4."
