  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a0046b1f74ec44f9c9baacdbd39d7435, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Narthex.Gameplay::Narthex.Gameplay.TutorialNarrativeSequenceHost
  serviceRoot: {fileID: 465223170}
  questSequenceHost: {fileID: 465223176}
  beats:
  - questId: QST-TUTO-001
    stageId: "\uC544\uB2E4\uB9C8\uC2A4 \uBCF8\uBD80"
    lines:
    - "\uC2DC\uC2A4\uD15C: \uC81C\uB2C8\uC2A4\uC758 \uD310\uB3C4\uB77C \uACF5\uC7A5\uC774
      \uD3C9\uC18C\uC640 \uB2E4\uB978 \uB08C\uC0C8\uB97C \uBCF4\uC778\uC9C0 \uC77C\uC8FC\uC77C\uC9F8\uAC00
      \uC9C0\uB0AC\uB2E4."
    - "\uC5D0\uC628: \uD310\uB3C4\uB77C \uACF5\uC7A5\uC774 \uD3C9\uC18C\uC640 \uB2E4\uB974\uAC8C
      \uBD84\uC8FC\uD55C \uBAA8\uC2B5\uC744 \uBCF4\uC774\uAE30 \uC2DC\uC791\uD588\uC5B4."
    - "\uC5D0\uC628: \uC774\uC81C\uB294 \uC6B0\uB9AC\uC758 \uACC4\uD68D\uC744 \uC2E4\uD589\uD560
      \uB54C\uAC00 \uB410\uC5B4. \uD504\uB85C\uBA54, \uC815\uB9D0 \uD560 \uC218 \uC788\uACA0\uC5B4?"
    - "\uD504\uB85C\uBA54: \uC751. \uB098\uB3C4 \uC624\uB7AB\uB3D9\uC548 \uC900\uBE44\uD574
      \uC654\uC5B4."
    - "\uC5D8\uB968: \uD14C\uC6B0\uC2A4\uC758 \uC810\uAC80\uC740 \uB05D\uB0AC\uC5B4.
      \uD6C8\uB828\uC7A5\uC5D0\uC11C \uB9C8\uC9C0\uB9C9\uC73C\uB85C \uC7A5\uBE44
      \uC0C1\uD0DC\uB97C \uD655\uC778\uD574."
    - "\uC544\uB974\uC628: \uD504\uB85C\uBA54, \uB098\uAC00\uAE30 \uC804\uC5D0 \uB9C8\uC9C0\uB9C9
      \uD6C8\uB828\uC744 \uD574 \uBCF4\uB294 \uAC8C \uC88B\uACA0\uC5B4. \uD14C\uC6B0\uC2A4\uB97C
      \uB530\uB77C\uAC00 \uBD10."
    - "\uD14C\uC6B0\uC2A4: \uC548\uB155 \uD504\uB85C\uBA54!"
    - "\uD14C\uC6B0\uC2A4: \uD6C8\uB828\uC7A5\uC740 \uC774\uCABD\uC774\uC57C. \uB098\uB97C
      \uB530\uB77C\uC640!"
    - "\uD504\uB85C\uBA54: \uC88B\uC544, \uD14C\uC6B0\uC2A4. \uC55E\uC7A5\uC11C \uC918."
    - "\uD14C\uC6B0\uC2A4: \uCD9C\uAD6C\uC758 \uC0AC\uB2E4\uB9AC\uB97C \uD0C0\uACE0
      \uC544\uB798\uB85C \uB0B4\uB824\uAC00\uBA74 \uD6C8\uB828\uC7A5\uC774\uC57C.
      \uB0B4\uAC00 \uBA3C\uC800 \uC548\uB0B4\uD560\uAC8C!"
    deferUntilPortalTargetId: 
    activateOnStart:
    - {fileID: 984369835}
    deactivateOnStart:
    - {fileID: 1697514729}
    - {fileID: 733579597}
    - {fileID: 823750073}
  - questId: QST-TUTO-002
    stageId: "\uD6C8\uB828\uC7A5"
    lines:
    - "\uD14C\uC6B0\uC2A4: \uC88B\uC544, \uBAB8\uB180\uB9BC\uC774 \uAC00\uBCCD\uB124!"
    - "\uD14C\uC6B0\uC2A4: \uB2E4\uC74C\uC740 \uC810\uD504 \uD68C\uD53C \uD6C8\uB828\uC774\uC57C.
      \uC55E\uC5D0\uC11C \uB0A0\uC544\uC624\uB294 \uB0AE\uC740 \uD22C\uC0AC\uCCB4\uB97C
      \uB6F0\uC5B4\uB118\uC5B4 \uBD10."
    - "\uD14C\uC6B0\uC2A4: SPACE\uB85C \uC810\uD504\uD574 3\uBC88 \uD53C\uD574\uC57C
      \uD574. \uD22C\uC0AC\uCCB4\uC5D0 \uB9DE\uC73C\uBA74 \uC774 \uAD6C\uAC04\uC744
      \uCC98\uC74C\uBD80\uD130 \uB2E4\uC2DC \uC2DC\uC791\uD560 \uAC70\uC57C!"
    deferUntilPortalTargetId: 
    activateOnStart:
    - {fileID: 1697514729}
    deactivateOnStart:
    - {fileID: 984369835}
    - {fileID: 733579597}
    - {fileID: 823750073}
  - questId: QST-TUTO-003
    stageId: "\uD6C8\uB828\uC7A5"
    lines:
    - "\uD14C\uC6B0\uC2A4: \uC644\uBCBD\uD574! \uC774\uC81C \uC9C4\uC9DC \uC804\uD22C
      \uD6C8\uB828\uC774\uC57C."
    - "\uD14C\uC6B0\uC2A4: \uD6C8\uB828\uC6A9 \uC5D0\uB108\uBBF8, \uC18C\uD658! \uAC81\uBA39\uC9C0
      \uB9C8. \uBB3C\uC9C0\uB294 \uC54A\uC544."
    - "\uD14C\uC6B0\uC2A4: \uB9C8\uC6B0\uC2A4 \uC67C\uCABD \uBC84\uD2BC\uC73C\uB85C
      \uACF5\uACA9\uD574 \uBD10. \uCEE4\uC11C\uAC00 \uC788\uB294 \uBC29\uD5A5\uC73C\uB85C
      \uBAB8\uC744 \uB3CC\uB824 3\uBC88 \uC774\uC5B4\uC11C \uC0AC\uC6A9\uD558\uBA74
      \uB3FC!"
    deferUntilPortalTargetId: 
    activateOnStart:
    - {fileID: 1697514729}
    deactivateOnStart:
    - {fileID: 984369835}
    - {fileID: 733579597}
    - {fileID: 823750073}
  - questId: QST-TUTO-004
    stageId: "\uD6C8\uB828\uC7A5"
    lines:
    - "\uD14C\uC6B0\uC2A4: \uC5EC\uAE30\uAC00 \uD6C8\uB828\uC7A5\uC774\uC57C! \uCD9C\uBC1C
      \uC804\uC5D0 \uBAB8\uC744 \uD480\uACE0 \uAC00\uC790."
    - "\uD14C\uC6B0\uC2A4: \uD6C8\uB828\uC7A5 \uC2DC\uC2A4\uD15C, \uC791\uB3D9! \uC9C0\uAE08\uBD80\uD130
      \uD6C8\uB828\uC6A9 \uC7A5\uCE58\uC640 \uC5D0\uB108\uBBF8\uB97C \uC18C\uD658\uD560\uAC8C."
    - "\uD14C\uC6B0\uC2A4: \uCCAB \uBC88\uC9F8\uB294 \uB300\uC2DC \uD6C8\uB828\uC774\uC57C.
      LEFT SHIFT\uB97C \uB204\uB974\uBA74 \uBE60\uB974\uAC8C \uC774\uB3D9\uD560 \uC218
      \uC788\uC5B4."
    - "\uD14C\uC6B0\uC2A4: \uD558\uB298\uC5D0\uC11C \uB5A8\uC5B4\uC9C0\uB294 \uB099\uD558\uBB3C\uC744
      \uB300\uC2DC\uB85C 3\uBC88 \uD53C\uD574 \uBD10!"
    deferUntilPortalTargetId: 
    activateOnStart:
    - {fileID: 1697514729}
    deactivateOnStart:
    - {fileID: 984369835}
    - {fileID: 733579597}
    - {fileID: 823750073}
  - questId: QST-TUTO-005
    stageId: "\uD6C8\uB828\uC7A5"
    lines:
    - "\uD14C\uC6B0\uC2A4: \uBA4B\uC9C4 \uACF5\uACA9\uC774\uC5C8\uC5B4!"
    - "\uD14C\uC6B0\uC2A4: \uB9C8\uC9C0\uB9C9\uC740 \uD6C8\uB828\uC6A9 \uB098\uB974\uD14D\uC2A4
      \uD384\uC2A4\uC57C. 2\uBC88 \uD0A4\uB97C \uB204\uB974\uBA74 \uC804\uBC29\uC73C\uB85C
      \uC5D0\uB108\uC9C0 \uB3C4\uD615\uC744 \uBC1C\uC0AC\uD560 \uC218 \uC788\uC5B4."
    - "\uD14C\uC6B0\uC2A4: \uC18C\uD658\uB41C \uD45C\uC801\uC744 \uD5A5\uD574 \uD384\uC2A4\uB97C
      \uBC1C\uC0AC\uD574 \uBD10!"
    deferUntilPortalTargetId: 
    activateOnStart:
    - {fileID: 1697514729}
    deactivateOnStart:
    - {fileID: 984369835}
    - {fileID: 733579597}
    - {fileID: 823750073}
  - questId: QST-TUTO-006
    stageId: "\uD6C8\uB828\uC7A5"
    lines:
    - "\uD06C\uB9AC\uC628: \uD504\uB85C\uBA54!"
    - "\uD06C\uB9AC\uC628: \uC5B8\uB2C8... \uC774\uAC70 \uCC59\uACA8 \uAC00."
    - "\uD504\uB85C\uBA54: \uC774\uAC8C \uBB50\uC57C?"
    - "\uD14C\uC6B0\uC2A4: \uC2A4\uCE94 \uC644\uB8CC. \uB354\uBE14 \uC810\uD504 \uBD80\uCE20\uC640
      \uB098\uB974\uD14D\uC2A4 \uD384\uC2A4\uC758 \uC2E4\uC804 \uC6B4\uC6A9 \uBAA8\uB4C8\uC774
      \uB4E4\uC5B4 \uC788\uC5B4."
    - "\uD14C\uC6B0\uC2A4: \uD6C8\uB828\uC7A5\uC5D0\uC11C \uC784\uC2DC\uB85C \uC5F4\uC5C8\uB358
      \uD384\uC2A4 \uAD8C\uD55C\uC744 \uC2E4\uC804 \uC7A5\uCC29 \uC0C1\uD0DC\uB85C
      \uC804\uD658\uD588\uC5B4. 2\uBC88 \uD0A4 \uC0AC\uC6A9\uBC95\uC740 \uADF8\uB300\uB85C\uC57C."
    - "\uD14C\uC6B0\uC2A4: \uBD80\uCE20\uB3C4 \uC7A5\uCC29\uB410\uC5B4. \uACF5\uC911\uC5D0\uC11C
      \uD55C \uBC88 \uB354 \uC810\uD504\uD574 \uB192\uC740 \uBC1C\uD310\uAE4C\uC9C0
      \uC62C\uB77C\uAC00 \uBD10."
    - "\uD14C\uC6B0\uC2A4: \uC55E\uC73C\uB85C \uBAA8\uD5D8 \uC911 \uC4F8 \uB9CC\uD55C
      \uBB3C\uAC74\uC744 \uCC3E\uC73C\uBA74 \uB0B4\uAC00 \uBC14\uB85C \uC54C\uB824\uC904\uAC8C."
    - "\uD504\uB85C\uBA54: \uACE0\uB9C8\uC6CC, \uD06C\uB9C1. \uB2E4\uB140\uC640\uC11C
      \uAC19\uC774 \uB610 \uB180\uC790."
    - "\uD06C\uB9AC\uC628: \uC751... \uC798 \uB2E4\uB140\uC640!"
    deferUntilPortalTargetId: TUTORIAL-TRAINING-EXIT
    activateOnStart:
    - {fileID: 1697514729}
    deactivateOnStart:
    - {fileID: 984369835}
    - {fileID: 733579597}
    - {fileID: 823750073}
  - questId: QST-TUTO-007
    stageId: "\uC678\uBD80 \uACBD\uACC4"
    lines:
    - "\uD14C\uC6B0\uC2A4: \uC774\uC57C, \uBC14\uAE65 \uACF5\uAE30\uB294 \uC815\uB9D0
      \uC624\uB79C\uB9CC\uC774\uC57C!"
    - "\uD504\uB85C\uBA54: \uB108\uB294 \uB85C\uBD07\uC778\uB370 \uACF5\uAE30\uAC00
      \uB290\uAEF4\uC838?"
    - "\uD14C\uC6B0\uC2A4: \uC0AC\uC18C\uD55C \uAC74 \uB118\uC5B4\uAC00\uACE0 \uC800
      \uBE44\uD589\uC120\uC744 \uBD10. \uC81C\uB2C8\uC2A4\uB85C \uC62C\uB77C\uAC08
      \uC218\uB2E8\uC774\uC57C."
    - "\uD14C\uC6B0\uC2A4: \uD5EC\uD14C\uAC00 \uBCF4\uC548\uD0A4\uB97C \uAC00\uC9C0\uACE0
      \uC788\uC5B4. \uADF8\uB7F0\uB370 \uC678\uACFD \uACBD\uBE44\uB4E4\uC774 \uBA3C\uC800
      \uC811\uADFC\uD558\uACE0 \uC788\uC5B4."
    - "\uD504\uB85C\uBA54: \uAE38\uC744 \uB9C9\uB294 \uC801\uBD80\uD130 \uCC98\uB9AC\uD558\uACE0
      \uD5EC\uD14C\uB97C \uB9CC\uB098\uB7EC \uAC00\uC790."
    - "\uD14C\uC6B0\uC2A4: \uC88B\uC544. \uC774 \uD1B5\uB85C\uB294 \uC77C\uC790\uC57C.
      \uC55E\uC758 \uB9B4\uB808\uC774\uB97C \uC5F4\uACE0 \uADF8\uB300\uB85C \uC804\uC9C4\uD558\uBA74
      \uB3FC."
    deferUntilPortalTargetId: 
    activateOnStart:
    - {fileID: 733579597}
    deactivateOnStart:
    - {fileID: 984369835}
    - {fileID: 1697514729}
    - {fileID: 823750073}
  - questId: QST-TUTO-008
    stageId: "\uAD11\uBB3C \uBCF4\uAD00\uC18C"
    lines:
    - "\uD14C\uC6B0\uC2A4: \uAD11\uBB3C \uC800\uC7A5\uACE0\uC5D0 \uD5EC\uD14C\uAC00
      \uC788\uC5B4. \uBCF4\uC548\uD0A4\uB97C \uC5BB\uC73C\uB824\uBA74 \uADF8\uB97C
      \uC9C0\uB098\uC57C \uD574."
    - "\uD504\uB85C\uBA54: \uC5EC\uAE30\uAE4C\uC9C0 \uC640\uC11C \uB3CC\uC544\uAC08
      \uC218\uB294 \uC5C6\uC5B4."
    - "\uD5EC\uD14C: \uC544\uB2E4\uB9C8\uC2A4\uC758 \uC544\uC774\uAC00 \uC5EC\uAE30\uAE4C\uC9C0
      \uB4E4\uC5B4\uC654\uAD70."
    - "\uD504\uB85C\uBA54: \uAE38\uC744 \uBE44\uCF1C \uC918. \uC6B0\uB9AC\uB294 \uD310\uB3C4\uB77C
      \uACF5\uC7A5\uC73C\uB85C \uAC00\uC57C \uD574."
    deferUntilPortalTargetId: TUTORIAL-ENCOUNTER-B-EXIT
    activateOnStart:
    - {fileID: 823750073}
    deactivateOnStart:
    - {fileID: 984369835}
    - {fileID: 1697514729}
    - {fileID: 733579597}
  - questId: QST-TUTO-007-A
    stageId: "\uC678\uACFD \uC804\uD22C I"
    lines:
    - "\uD14C\uC6B0\uC2A4: \uC678\uACFD \uD1B5\uB85C\uAC00 \uBD09\uC1C4\uB410\uC5B4.
      \uC811\uADFC\uD558\uB294 \uC801\uC744 \uC21C\uC11C\uB300\uB85C \uCC98\uB9AC\uD574."
    - "\uD504\uB85C\uBA54: \uC54C\uACA0\uC5B4. \uD55C \uBC88\uC5D0 \uD558\uB098\uC529
      \uC815\uB9AC\uD560\uAC8C."
    - "\uD14C\uC6B0\uC2A4: \uB9C8\uC9C0\uB9C9 \uC801\uAE4C\uC9C0 \uC4F0\uB7EC\uB728\uB9AC\uBA74
      \uCD9C\uAD6C \uAC8C\uC774\uD2B8\uAC00 \uC5F4\uB9B4 \uAC70\uC57C."
    deferUntilPortalTargetId: TUTORIAL-Z03-EXIT
    activateOnStart: []
    deactivateOnStart: []
  - questId: QST-TUTO-007-B
    stageId: "\uC678\uACFD \uC804\uD22C II"
    lines:
    - "\uD14C\uC6B0\uC2A4: \uB450 \uBC88\uC9F8 \uBC29\uC5B4\uC120\uC774\uC57C. \uC774\uBC88\uC5D0\uB294
      \uC801\uB4E4\uC774 \uB3D9\uC2DC\uC5D0 \uC6C0\uC9C1\uC5EC."
    - "\uD504\uB85C\uBA54: \uACE0\uC800\uCC28\uB97C \uC774\uC6A9\uD574\uC11C \uC218\uB97C
      \uC904\uC5EC \uBCFC\uAC8C."
    - "\uD14C\uC6B0\uC2A4: \uC774 \uAD6C\uC5ED\uC744 \uB118\uC73C\uBA74 \uD5EC\uD14C\uAC00
      \uC788\uB294 \uAD11\uBB3C \uC800\uC7A5\uACE0\uC57C."
    deferUntilPortalTargetId: TUTORIAL-ENCOUNTER-A-EXIT
    activateOnStart: []
    deactivateOnStart: []
