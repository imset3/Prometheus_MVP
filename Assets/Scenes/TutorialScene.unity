  m_Name: 
  m_EditorClassIdentifier: Narthex.Gameplay::Narthex.Gameplay.TutorialQuestSequenceHost
  serviceRoot: {fileID: 465223170}
  saveSystemHost: {fileID: 465223174}
  questManagerHost: {fileID: 465223177}
  questSequence:
  - {fileID: 11400000, guid: d31dab047603147fe9ffcf057669514d, type: 2}
  - {fileID: 11400000, guid: 1de3bee7ec05f44859ace4fa5950b2c4, type: 2}
  - {fileID: 11400000, guid: 7a948ab8a878444b8af4b3529f81cbb8, type: 2}
  - {fileID: 11400000, guid: 52995dda3c0554fd19424243b4268845, type: 2}
  - {fileID: 11400000, guid: f66fdecbd28634437b20f03c6bd13d8e, type: 2}
  - {fileID: 11400000, guid: b4472259cfd9d4c67ae6e35492185366, type: 2}
  - {fileID: 11400000, guid: 407f0de82bb334d8cb731d75ddedb6d4, type: 2}
  - {fileID: 11400000, guid: 08e5362aec7944e049bd5ce0f2fdac6e, type: 2}
  - {fileID: 11400000, guid: 9b72d7891b43c464aa55aa0027fb6415, type: 2}
  - {fileID: 11400000, guid: 6bfb197efe8304a4c863834fb244d633, type: 2}
  objectiveTexts:
  - "\uD14C\uC6B0\uC2A4\uB97C \uB530\uB77C HQ \uCD9C\uAD6C\uB85C \uC774\uB3D9"
  - "Left Shift\uB85C \uB300\uC2DC\uB97C 3\uD68C \uC0AC\uC6A9"
  - "Space\uB85C \uC7A5\uC560\uBB3C 3\uAC1C\uB97C \uB118\uC5B4 \uC774\uB3D9"
  - "\uB9C8\uC6B0\uC2A4 \uC67C\uCABD \uBC84\uD2BC\uC73C\uB85C \uCEE4\uC11C \uBC29\uD5A5\uC744
    \uD5A5\uD574 \uAE30\uBCF8 \uACF5\uACA9 3\uD68C"
  - "2\uB85C \uD29C\uD1A0\uB9AC\uC5BC \uBAA8\uB4C8 \uC0AC\uC6A9"
  - "\uC7A5\uBE44 \uD328\uD0A4\uC9C0\uB97C \uBC1B\uACE0, \uB354\uBE14 \uC810\uD504\uB97C
    1\uD68C \uC0AC\uC6A9\uD55C \uB4A4 I\uB85C \uBAA8\uB4C8 \uD2B8\uB9AC \uC5F4\uAE30"
  - "\uC678\uBD80 \uC9C1\uC120 \uD1B5\uB85C \uB05D\uC758 \uB9B4\uB808\uC774 \uD65C\uC131\uD654"
  - "\uC678\uACFD \uC804\uD22C I\uC758 \uC801 3\uAE30 \uCC98\uCE58"
  - "\uC678\uACFD \uC804\uD22C II\uC758 \uC801\uC744 \uBAA8\uB450 \uCC98\uCE58"
  - "\uD5EC\uD14C \uCC98\uCE58"
