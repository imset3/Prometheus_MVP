  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a0046b1f74ec44f9c9baacdbd39d7435, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Narthex.Gameplay::Narthex.Gameplay.TutorialNarrativeSequenceHost
  serviceRoot: {fileID: 465223170}
  questSequenceHost: {fileID: 465223176}
  beats:
  - questId: QST-TUTO-001
    stageId: "\uC544\uB2E4\uB9C8\uC2A4 \uBCF8\uBD80"
    lines:
    - "\uC2DC\uC2A4\uD15C: \uC81C\uB2C8\uC2A4\uC758 \uD310\uB3C4\uB77C \uACF5\uC7A5\uC774
      \uD3C9\uC18C\uC640 \uB2E4\uB978 \uB08C\uC0C8\uB97C \uBCF4\uC778\uC9C0 \uC77C\uC8FC\uC77C\uC9F8\uAC00
      \uC9C0\uB0AC\uB2E4."
    - "\uB3D9\uB8CC: \uD504\uB85C\uBA54, \uB098\uAC00\uAE30 \uC804\uC5D0 \uB9C8\uC9C0\uB9C9
      \uD6C8\uB828\uC744 \uD574 \uBCF4\uB294 \uAC8C \uC88B\uACA0\uC5B4. \uD14C\uC6B0\uC2A4\uB97C
      \uB530\uB77C\uAC00 \uBD10."
    - "\uD14C\uC6B0\uC2A4: \uC548\uB155 \uC5EC\uD589 \uBA54\uC774\uD2B8! \uD6C8\uB828\uC7A5\uC740
      \uC774\uCABD\uC774\uC57C."
    - "\uD504\uB85C\uBA54: \uC88B\uC544, \uD14C\uC6B0\uC2A4. \uC55E\uC7A5\uC11C \uC918."
    activateOnStart:
    - {fileID: 984369835}
    deactivateOnStart:
    - {fileID: 1697514729}
    - {fileID: 733579597}
    - {fileID: 823750073}
  - questId: QST-TUTO-002
    stageId: "\uD6C8\uB828\uC7A5"
    lines:
    - "\uD14C\uC6B0\uC2A4: \uBA3C\uC800 \uC810\uD504\uBD80\uD130 \uC775\uD600 \uBCF4\uC790.
      \uC55E\uC758 \uC7A5\uC560\uBB3C\uC744 \uB118\uC5B4\uC11C \uC640!"
    activateOnStart:
    - {fileID: 1697514729}
    deactivateOnStart:
    - {fileID: 984369835}
    - {fileID: 733579597}
    - {fileID: 823750073}
  - questId: QST-TUTO-003
    stageId: "\uD6C8\uB828\uC7A5"
    lines:
    - "\uD14C\uC6B0\uC2A4: \uC88B\uC544! \uC774\uC81C \uD6C8\uB828\uC6A9 \uC5D0\uB108\uBBF8\uB97C
      \uAE30\uBCF8 \uACF5\uACA9\uC73C\uB85C \uC0C1\uB300\uD574 \uBCF4\uC790."
    activateOnStart:
    - {fileID: 1697514729}
    deactivateOnStart:
    - {fileID: 984369835}
    - {fileID: 733579597}
    - {fileID: 823750073}
  - questId: QST-TUTO-004
    stageId: "\uD6C8\uB828\uC7A5"
    lines:
    - "\uD14C\uC6B0\uC2A4: \uC704\uD5D8\uD560 \uB550 \uB300\uC2DC\uB85C \uD53C\uD558\uB294
      \uAC70\uC57C. \uBC1C\uBC11\uC5D0 \uD798\uC744 \uBAA8\uC544 \uBD10!"
    activateOnStart:
    - {fileID: 1697514729}
    deactivateOnStart:
    - {fileID: 984369835}
    - {fileID: 733579597}
    - {fileID: 823750073}
  - questId: QST-TUTO-005
    stageId: "\uD6C8\uB828\uC7A5"
    lines:
    - "\uD14C\uC6B0\uC2A4: \uB098\uB974\uD14D\uC2A4\uC758 \uD384\uC2A4 \uAE30\uB2A5\uC744
      \uC368 \uBCF4\uC790. \uC5EC\uB7EC \uC801\uC744 \uBC00\uC5B4\uB0BC \uC218 \uC788\uC5B4."
    activateOnStart:
    - {fileID: 1697514729}
    deactivateOnStart:
    - {fileID: 984369835}
    - {fileID: 733579597}
    - {fileID: 823750073}
  - questId: QST-TUTO-006
    stageId: "\uD6C8\uB828\uC7A5"
    lines:
    - "\uD14C\uC6B0\uC2A4: \uBAA8\uB4C8\uC740 \uC804\uD22C \uBC29\uC2DD\uC744 \uBC14\uAFD4
      \uC918. \uC7A5\uCC29 \uC0C1\uD0DC\uB97C \uD655\uC778\uD574 \uBD10."
    activateOnStart:
    - {fileID: 1697514729}
    deactivateOnStart:
    - {fileID: 984369835}
    - {fileID: 733579597}
    - {fileID: 823750073}
  - questId: QST-TUTO-007
    stageId: "\uC678\uBD80 \uACBD\uACC4"
    lines:
    - "\uD14C\uC6B0\uC2A4: \uD06C\uB9AC\uC628\uC774 \uC900 \uBD80\uCE20\uB97C \uC2A4\uCE94\uD574
      \uBCFC\uAC8C. \uAC00\uAE4C\uC774\uC5D0\uC11C F\uB97C \uB20C\uB7EC \uBD10."
    - "\uD14C\uC6B0\uC2A4: \uB354\uBE14 \uC810\uD504\uB97C \uC5BB\uC5C8\uC5B4! \uC774\uC81C
      \uC1A1\uC2E0\uD0D1\uC744 \uD65C\uC131\uD654\uD558\uC790."
    activateOnStart:
    - {fileID: 733579597}
    deactivateOnStart:
    - {fileID: 984369835}
    - {fileID: 1697514729}
    - {fileID: 823750073}
  - questId: QST-TUTO-008
    stageId: "\uAD11\uBB3C \uBCF4\uAD00\uC18C"
    lines:
    - "\uD14C\uC6B0\uC2A4: \uAD11\uBB3C \uBCF4\uAD00\uC18C\uC5D0 \uD5EC\uD14C\uAC00
      \uC788\uC5B4. \uBCF4\uC548\uD0A4\uB97C \uC5BB\uC73C\uB824\uBA74 \uADF8\uB97C
      \uC9C0\uB098\uC57C \uD574."
